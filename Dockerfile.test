FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /police-cad-api .

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /police-cad-api /usr/local/bin/police-cad-api
EXPOSE 8081
CMD ["police-cad-api"]
